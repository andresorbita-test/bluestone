# Archivo de ejemplo de variables de entorno
# Copia este archivo a .env.local y reemplaza los valores
# NUNCA commitear .env o .env.local al repositorio

# API Configuration (Solo URLs públicas)
VITE_API_URL=https://api.example.com

# Public Keys (Solo datos públicos, NO secretos)
VITE_STRIPE_PUBLIC_KEY=pk_test_ejemplo
VITE_GOOGLE_MAP_KEY=AIzaSy...

# Si necesitas secretos (Stripe key, API keys, etc):
# - Configúralos SOLO en Vercel Dashboard
# - NO los agregues aquí
# - El backend proxy debe usar process.env.SECRETO
